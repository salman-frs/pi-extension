# Copy this file to .env before starting the local research stack.
# Use a long random value for SEARXNG_SECRET.

SEARXNG_SECRET=replace-with-a-long-random-secret
PORT=8787
HOST=0.0.0.0
REQUEST_TIMEOUT_MS=30000
MAX_FETCHED_SOURCES=6
SEARXNG_URL=http://localhost:8080
RESEARCH_API_KEY=replace-with-a-long-random-secret
USER_AGENT=pi-research-backend/0.3.0
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true
BROWSER_MODE=auto
ALLOW_PRIVATE_FETCH_HOSTS=127.0.0.1
CACHE_ENABLED=true
SEARCH_CACHE_TTL_MS=300000
FETCH_CACHE_TTL_MS=900000
RENDERED_FETCH_CACHE_TTL_MS=900000
RESEARCH_CACHE_TTL_MS=300000
ANALYZE_CACHE_TTL_MS=300000
TELEMETRY_ENABLED=true

# optional for qa test benchmarking
TAVILY_BASE_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=4
TAVILY_API_KEY=your_real_key_here